                "value": "{{api_key}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"new.staff\",\n    \"password\": \"Password123!\",\n    \"hospital_code\": \"HOSPITAL_A\"\n}"
